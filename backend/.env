# Environment variables for the Academia backend

# MongoDB connection string
# Replace with your actual MongoDB URI (e.g., for local MongoDB: mongodb://localhost:27017/academia)
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/academia?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/academia

# Server port (optional, defaults to 5000)
PORT=5000

# JWT Secret for authentication tokens
JWT_SECRET=academia_secret_key_2026_secure_token

# Other environment variables can be added here as needed